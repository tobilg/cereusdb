{
  "name": "@cereusdb/playground",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "check-deps": "test -f ../minimal/dist/index.js || (echo 'Error: @cereusdb/minimal has not been built yet.' && echo 'Run the following from the repo root first:' && echo '' && echo '  make package-minimal' && exit 1)",
    "predev": "npm run check-deps",
    "dev": "vite",
    "prebuild": "npm run check-deps",
    "build": "tsc --noEmit && vite build",
    "build:release": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.81.1"
  }
}
