diff --git a/c/sedona-proj/build.rs b/c/sedona-proj/build.rs
new file mode 100644
index 0000000..512ff16
--- /dev/null
+++ b/c/sedona-proj/build.rs
@@ -0,0 +1,69 @@
+use std::env;
+use std::fs;
+use std::path::PathBuf;
+use std::process::Command;
+
+fn main() {
+    println!("cargo:rerun-if-env-changed=SEDONA_WASM_PROJ_DB_PATH");
+    println!("cargo:rerun-if-env-changed=SQLITE3_INCLUDE_DIR");
+    println!("cargo:rerun-if-changed=src/proj_memvfs.c");
+
+    if env::var("CARGO_CFG_TARGET_ARCH").as_deref() != Ok("wasm32") {
+        return;
+    }
+
+    let proj_db_path = env::var("SEDONA_WASM_PROJ_DB_PATH")
+        .expect("SEDONA_WASM_PROJ_DB_PATH must point to proj.db for wasm32 builds");
+    let sqlite_include_dir = env::var("SQLITE3_INCLUDE_DIR")
+        .expect("SQLITE3_INCLUDE_DIR must point to the SQLite headers for wasm32 builds");
+    let out_dir = PathBuf::from(env::var("OUT_DIR").expect("OUT_DIR is not set"));
+
+    println!("cargo:rerun-if-changed={proj_db_path}");
+
+    let generated_rs = out_dir.join("embedded_proj_db.rs");
+    let generated = format!(
+        "pub static PROJ_DB: &[u8] = include_bytes!(r#\"{}\"#);\n",
+        proj_db_path
+    );
+    fs::write(&generated_rs, generated).expect("Failed to write embedded proj.db module");
+
+    let obj_path = out_dir.join("proj_memvfs.o");
+    let lib_path = out_dir.join("libsedona_proj_memvfs.a");
+
+    run(
+        "emcc",
+        &[
+            "-c".to_string(),
+            "src/proj_memvfs.c".to_string(),
+            "-o".to_string(),
+            obj_path.display().to_string(),
+            "-I".to_string(),
+            sqlite_include_dir,
+            "-Oz".to_string(),
+            "-DNDEBUG".to_string(),
+        ],
+    );
+
+    run(
+        "emar",
+        &[
+            "crs".to_string(),
+            lib_path.display().to_string(),
+            obj_path.display().to_string(),
+        ],
+    );
+
+    println!("cargo:rustc-link-search=native={}", out_dir.display());
+    println!("cargo:rustc-link-lib=static=sedona_proj_memvfs");
+}
+
+fn run(program: &str, args: &[String]) {
+    let status = Command::new(program)
+        .args(args)
+        .status()
+        .unwrap_or_else(|error| panic!("Failed to run {program}: {error}"));
+
+    if !status.success() {
+        panic!("{program} failed with status {status}");
+    }
+}
