+// specific language governing permissions and limitations
+// under the License.
+use std::sync::Arc;
+
+use arrow_array::{builder::BinaryBuilder, types::Float64Type, Array, PrimitiveArray};
+use arrow_schema::DataType;
+use datafusion_common::{cast::as_float64_array, error::Result, DataFusionError};
+use datafusion_expr::{ColumnarValue, Volatility};
+use geo_traits::{Dimensions, GeometryTrait};
+use sedona_expr::{
+    item_crs::ItemCrsKernel,
+    scalar_udf::{SedonaScalarKernel, SedonaScalarUDF},
+};
+use sedona_geometry::{
+    bounds::{geo_traits_bounds_xy, geo_traits_bounds_z},
+    interval::{Interval, IntervalTrait},
+    wkb_factory::{
+        write_wkb_coord, write_wkb_polygon_header, write_wkb_polygon_ring_header,
+        WKB_MIN_PROBABLE_BYTES,
+    },
+};
+use sedona_schema::{
+    datatypes::{SedonaType, WKB_GEOMETRY},
+    matchers::ArgMatcher,
+};
+use wkb::reader::Wkb;
+
+use crate::executor::WkbExecutor;
+
+/// ST_Expand() scalar UDF
+///
+/// Expands the bounding rectangle of a geometry and returns it as a polygon.
+pub fn st_expand_udf() -> SedonaScalarUDF {
+    SedonaScalarUDF::new(
+        "st_expand",
+        ItemCrsKernel::wrap_impl(vec![
+            Arc::new(STExpand {
+                mode: ExpandMode::Uniform,
+            }),
+            Arc::new(STExpand {
+                mode: ExpandMode::PerAxis,
+            }),
+            Arc::new(STExpand {
+                mode: ExpandMode::PerAxisAndZ,
+            }),
+        ]),
+        Volatility::Immutable,
+    )
+}
+
+#[derive(Debug, Clone, Copy)]
+enum ExpandMode {
+    Uniform,
+    PerAxis,
+    PerAxisAndZ,
+}
+
+#[derive(Debug)]
+struct STExpand {
+    mode: ExpandMode,
+}
+
+impl SedonaScalarKernel for STExpand {
+    fn return_type(&self, args: &[SedonaType]) -> Result<Option<SedonaType>> {
+        let matcher = match self.mode {
+            ExpandMode::Uniform => ArgMatcher::new(
+                vec![ArgMatcher::is_geometry(), ArgMatcher::is_numeric()],
+                WKB_GEOMETRY,
+            ),
+            ExpandMode::PerAxis => ArgMatcher::new(
+                vec![
+                    ArgMatcher::is_geometry(),
+                    ArgMatcher::is_numeric(),
+                    ArgMatcher::is_numeric(),
+                ],
+                WKB_GEOMETRY,
+            ),
+            ExpandMode::PerAxisAndZ => ArgMatcher::new(
+                vec![
+                    ArgMatcher::is_geometry(),
+                    ArgMatcher::is_numeric(),
+                    ArgMatcher::is_numeric(),
+                    ArgMatcher::is_numeric(),
+                ],
+                WKB_GEOMETRY,
+            ),
+        };
+
+        matcher.match_args(args)
+    }
+
+    fn invoke_batch(
+        &self,
+        arg_types: &[SedonaType],
+        args: &[ColumnarValue],
+    ) -> Result<ColumnarValue> {
+        let executor = WkbExecutor::new(arg_types, args);
+        let mut builder = BinaryBuilder::with_capacity(
+            executor.num_iterations(),
+            WKB_MIN_PROBABLE_BYTES * 6 * executor.num_iterations(),
+        );
+
+        let delta_arrays = args[1..]
+            .iter()
+            .map(|arg| arg.cast_to(&DataType::Float64, None)?.to_array(executor.num_iterations()))
+            .collect::<Result<Vec<Arc<dyn Array>>>>()?;
+        let delta_f64_arrays = delta_arrays
+            .iter()
+            .map(|array| as_float64_array(array))
+            .collect::<Result<Vec<_>>>()?;
+        let mut deltas = ExpandDeltas::new(self.mode, &delta_f64_arrays);
+
+        executor.execute_wkb_void(|maybe_wkb| {
+            match (maybe_wkb, deltas.next().unwrap()) {
+                (Some(wkb), Some((delta_x, delta_y, delta_z))) => {
+                    invoke_scalar(&wkb, delta_x, delta_y, delta_z, &mut builder)?;
+                    builder.append_value([]);
+                }
+                _ => builder.append_null(),
+            }
+            Ok(())
+        })?;
+
+        executor.finish(Arc::new(builder.finish()))
+    }
+}
+
+struct ExpandDeltas<'a> {
+    mode: ExpandMode,
+    index: usize,
+    delta_x: &'a PrimitiveArray<Float64Type>,
+    delta_y: Option<&'a PrimitiveArray<Float64Type>>,
+    delta_z: Option<&'a PrimitiveArray<Float64Type>>,
+}
+
+impl<'a> ExpandDeltas<'a> {
+    fn new(mode: ExpandMode, arrays: &[&'a PrimitiveArray<Float64Type>]) -> Self {
+        match mode {
+            ExpandMode::Uniform => Self {
+                mode,
+                index: 0,
+                delta_x: arrays[0],
+                delta_y: None,
+                delta_z: None,
+            },
+            ExpandMode::PerAxis => Self {
+                mode,
+                index: 0,
+                delta_x: arrays[0],
+                delta_y: Some(arrays[1]),
+                delta_z: None,
+            },
+            ExpandMode::PerAxisAndZ => Self {
+                mode,
+                index: 0,
+                delta_x: arrays[0],
+                delta_y: Some(arrays[1]),
+                delta_z: Some(arrays[2]),
+            },
+        }
+    }
+}
+
+impl Iterator for ExpandDeltas<'_> {
+    type Item = Option<(f64, f64, Option<f64>)>;
+
+    fn next(&mut self) -> Option<Self::Item> {
+        let i = self.index;
+        self.index += 1;
+
+        let is_null = self.delta_x.is_null(i)
+            || self.delta_y.is_some_and(|array| array.is_null(i))
+            || self.delta_z.is_some_and(|array| array.is_null(i));
+        if is_null {
+            return Some(None);
+        }
+
+        let delta_x = self.delta_x.value(i);
+        Some(match self.mode {
+            ExpandMode::Uniform => Some((delta_x, delta_x, Some(delta_x))),
+            ExpandMode::PerAxis => Some((delta_x, self.delta_y.unwrap().value(i), None)),
+            ExpandMode::PerAxisAndZ => Some((
+                delta_x,
+                self.delta_y.unwrap().value(i),
+                Some(self.delta_z.unwrap().value(i)),
+            )),
+        })
+    }
+}
+
+fn invoke_scalar(
+    wkb: &Wkb,
+    delta_x: f64,
+    delta_y: f64,
+    delta_z: Option<f64>,
+    writer: &mut impl std::io::Write,
+) -> Result<()> {
+    let bounds = geo_traits_bounds_xy(wkb).map_err(|e| DataFusionError::External(Box::new(e)))?;
+    let output_dims = match wkb.dim() {
+        Dimensions::Xyz | Dimensions::Xyzm => Dimensions::Xyz,
+        _ => Dimensions::Xy,
+    };
+
+    if bounds.is_empty() {
+        return write_wkb_polygon_header(writer, output_dims, 0)
+            .map_err(|e| DataFusionError::External(Box::new(e)));
+    }
+
+    let x = bounds.x().expand_by(delta_x);
+    let y = bounds.y().expand_by(delta_y);
+    let z = if output_dims == Dimensions::Xyz {
+        let z_bounds =
+            geo_traits_bounds_z(wkb).map_err(|e| DataFusionError::External(Box::new(e)))?;
+        Some(match delta_z {
+            Some(delta) => z_bounds.expand_by(delta),
+            None => z_bounds,
+        })
+    } else {
+        None
+    };
+
+    write_expanded_envelope(writer, output_dims, x.lo(), y.lo(), x.hi(), y.hi(), z.as_ref())
+}
+
+fn write_expanded_envelope(
+    writer: &mut impl std::io::Write,
+    dims: Dimensions,
+    min_x: f64,
+    min_y: f64,
+    max_x: f64,
+    max_y: f64,
+    z: Option<&Interval>,
+) -> Result<()> {
+    write_wkb_polygon_header(writer, dims, 1)
+        .map_err(|e| DataFusionError::External(Box::new(e)))?;
+    write_wkb_polygon_ring_header(writer, 5)
+        .map_err(|e| DataFusionError::External(Box::new(e)))?;
+
+    if let Some(z) = z {
+        let min_z = z.lo();
+        let max_z = z.hi();
+        for coord in [
+            (min_x, min_y, min_z),
+            (min_x, max_y, min_z),
+            (max_x, max_y, max_z),
+            (max_x, min_y, max_z),
+            (min_x, min_y, min_z),
+        ] {
+            write_wkb_coord(writer, coord).map_err(|e| DataFusionError::External(Box::new(e)))?;
+        }
+    } else {
+        for coord in [
+            (min_x, min_y),
+            (min_x, max_y),
+            (max_x, max_y),
+            (max_x, min_y),
+            (min_x, min_y),
+        ] {
+            write_wkb_coord(writer, coord).map_err(|e| DataFusionError::External(Box::new(e)))?;
+        }
+    }
+
+    Ok(())
+}
