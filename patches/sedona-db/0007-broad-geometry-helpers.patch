+use std::{str::FromStr, sync::Arc};
+
+use arrow_array::builder::BinaryBuilder;
+use arrow_schema::DataType;
+use datafusion_common::error::{DataFusionError, Result};
+use datafusion_common::{cast::as_string_view_array, exec_datafusion_err};
+use datafusion_expr::ColumnarValue;
+use geo_types::Geometry;
+use sedona_expr::scalar_udf::{ScalarKernelRef, SedonaScalarKernel};
+use sedona_functions::executor::WkbExecutor;
+use sedona_geometry::wkb_factory::WKB_MIN_PROBABLE_BYTES;
+use sedona_schema::{
+    datatypes::{SedonaType, WKB_GEOMETRY},
+    matchers::ArgMatcher,
+};
+use wkb::{writer::WriteOptions, Endianness};
+
+/// ST_GeomFromGeoJSON() kernel implementation
+pub fn st_geomfromgeojson_impl() -> Vec<ScalarKernelRef> {
+    vec![Arc::new(STGeomFromGeoJSON {})]
+}
+
+#[derive(Debug)]
+struct STGeomFromGeoJSON {}
+
+impl SedonaScalarKernel for STGeomFromGeoJSON {
+    fn return_type(&self, args: &[SedonaType]) -> Result<Option<SedonaType>> {
+        let matcher = ArgMatcher::new(vec![ArgMatcher::is_string()], WKB_GEOMETRY);
+        matcher.match_args(args)
+    }
+
+    fn invoke_batch(
+        &self,
+        arg_types: &[SedonaType],
+        args: &[ColumnarValue],
+    ) -> Result<ColumnarValue> {
+        let executor = WkbExecutor::new(arg_types, args);
+        let arg_array = args[0]
+            .cast_to(&DataType::Utf8View, None)?
+            .to_array(executor.num_iterations())?;
+
+        let mut builder = BinaryBuilder::with_capacity(
+            executor.num_iterations(),
+            WKB_MIN_PROBABLE_BYTES * executor.num_iterations(),
+        );
+
+        for item in as_string_view_array(&arg_array)? {
+            if let Some(geojson_str) = item {
+                invoke_scalar(geojson_str, &mut builder)?;
+                builder.append_value([]);
+            } else {
+                builder.append_null();
+            }
+        }
+
+        executor.finish(Arc::new(builder.finish()))
+    }
+}
+
+fn invoke_scalar(geojson_str: &str, builder: &mut BinaryBuilder) -> Result<()> {
+    let geojson = geojson::GeoJson::from_str(geojson_str)
+        .map_err(|err| exec_datafusion_err!("GeoJSON parse error: {err}"))?;
+    let geometry = Geometry::<f64>::try_from(geojson)
+        .map_err(|err| exec_datafusion_err!("GeoJSON conversion error: {err}"))?;
+
+    wkb::writer::write_geometry(
+        builder,
+        &geometry,
+        &WriteOptions {
+            endianness: Endianness::LittleEndian,
+        },
+    )
+    .map_err(|err| DataFusionError::External(Box::new(err)))
+}
