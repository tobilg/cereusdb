+use std::sync::Arc;
+
+use arrow_array::{builder::BinaryBuilder, Array};
+use arrow_schema::DataType;
+use datafusion_common::{cast::as_float64_array, error::Result, scalar::ScalarValue};
+use datafusion_expr::{ColumnarValue, Volatility};
+use sedona_expr::scalar_udf::{SedonaScalarKernel, SedonaScalarUDF};
+use sedona_geometry::wkb_factory::{wkb_rect, WKB_MIN_PROBABLE_BYTES};
+use sedona_schema::{
+    datatypes::{SedonaType, WKB_GEOMETRY},
+    matchers::ArgMatcher,
+};
+
+use crate::{executor::WkbExecutor, st_setsrid::SRIDifiedKernel};
+
+/// ST_MakeEnvelope() scalar UDF implementation
+///
+/// Creates a rectangular polygon from min/max coordinates.
+pub fn st_makeenvelope_udf() -> SedonaScalarUDF {
+    let kernel = Arc::new(STMakeEnvelope {});
+    let sridified_kernel = Arc::new(SRIDifiedKernel::new(kernel.clone()));
+
+    SedonaScalarUDF::new(
+        "st_makeenvelope",
+        vec![sridified_kernel, kernel],
+        Volatility::Immutable,
+    )
+}
+
+#[derive(Debug)]
+struct STMakeEnvelope {}
+
+impl SedonaScalarKernel for STMakeEnvelope {
+    fn return_type(&self, args: &[SedonaType]) -> Result<Option<SedonaType>> {
+        let matcher = ArgMatcher::new(
+            vec![
+                ArgMatcher::is_numeric(),
+                ArgMatcher::is_numeric(),
+                ArgMatcher::is_numeric(),
+                ArgMatcher::is_numeric(),
+            ],
+            WKB_GEOMETRY,
+        );
+        matcher.match_args(args)
+    }
+
+    fn invoke_batch(
+        &self,
+        arg_types: &[SedonaType],
+        args: &[ColumnarValue],
+    ) -> Result<ColumnarValue> {
+        let executor = WkbExecutor::new(arg_types, args);
+        let coord_values = args
+            .iter()
+            .map(|arg| arg.cast_to(&DataType::Float64, None))
+            .collect::<Result<Vec<_>>>()?;
+
+        let all_scalars = coord_values
+            .iter()
+            .all(|value| matches!(value, ColumnarValue::Scalar(_)));
+
+        if all_scalars {
+            let scalar_coords = coord_values
+                .iter()
+                .map(|value| match value {
+                    ColumnarValue::Scalar(ScalarValue::Float64(v)) => Ok(*v),
+                    _ => unreachable!("expected Float64 scalar"),
+                })
+                .collect::<Result<Vec<_>>>()?;
+
+            if scalar_coords.iter().any(|coord| coord.is_none()) {
+                return Ok(ScalarValue::Binary(None).into());
+            }
+
+            let wkb = wkb_rect(
+                scalar_coords[0].unwrap(),
+                scalar_coords[1].unwrap(),
+                scalar_coords[2].unwrap(),
+                scalar_coords[3].unwrap(),
+            )
+            .map_err(|err| datafusion_common::DataFusionError::External(Box::new(err)))?;
+            return Ok(ScalarValue::Binary(Some(wkb)).into());
+        }
+
+        let coord_arrays = coord_values
+            .iter()
+            .map(|value| value.to_array(executor.num_iterations()))
+            .collect::<Result<Vec<Arc<dyn Array>>>>()?;
+        let coord_f64_arrays = coord_arrays
+            .iter()
+            .map(|array| as_float64_array(array))
+            .collect::<Result<Vec<_>>>()?;
+
+        let mut builder = BinaryBuilder::with_capacity(
+            executor.num_iterations(),
+            WKB_MIN_PROBABLE_BYTES * 5 * executor.num_iterations(),
+        );
+
+        for row_idx in 0..executor.num_iterations() {
+            if coord_f64_arrays.iter().any(|array| array.is_null(row_idx)) {
+                builder.append_null();
+                continue;
+            }
+
+            let min_x = coord_f64_arrays[0].value(row_idx);
+            let min_y = coord_f64_arrays[1].value(row_idx);
+            let max_x = coord_f64_arrays[2].value(row_idx);
+            let max_y = coord_f64_arrays[3].value(row_idx);
+            let wkb = wkb_rect(min_x, min_y, max_x, max_y)
+                .map_err(|err| datafusion_common::DataFusionError::External(Box::new(err)))?;
+            builder.append_value(wkb);
+        }
+
+        Ok(ColumnarValue::Array(Arc::new(builder.finish())))
+    }
+}
