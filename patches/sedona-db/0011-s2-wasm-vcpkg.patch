+fn configure_wasm_vcpkg_toolchain(config: &mut cmake::Config) {
+    println!("cargo:rerun-if-env-changed=VCPKG_ROOT");
+    println!("cargo:rerun-if-env-changed=VCPKG_TARGET_TRIPLET");
+    println!("cargo:rerun-if-env-changed=VCPKG_INSTALLED_DIR");
+    println!("cargo:rerun-if-env-changed=EMSCRIPTEN_ROOT");
+    println!("cargo:rerun-if-env-changed=EMSDK");
+
+    if env::var("CARGO_CFG_TARGET_ARCH").as_deref() != Ok("wasm32") {
+        return;
+    }
+
+    config.no_default_flags(true);
+
+    let repo_root = repo_root_from_manifest_dir();
+    let vcpkg_root = env::var("VCPKG_ROOT")
+        .unwrap_or_else(|_| repo_root.join("deps").join("vcpkg").display().to_string());
+    let installed_dir = env::var("VCPKG_INSTALLED_DIR").unwrap_or_else(|_| {
+        repo_root
+            .join("build")
+            .join("vcpkg")
+            .join("s2-installed")
+            .display()
+            .to_string()
+    });
+    let target_triplet =
+        env::var("VCPKG_TARGET_TRIPLET").unwrap_or_else(|_| "wasm32-emscripten".to_string());
+    let emscripten_root =
+        env::var("EMSCRIPTEN_ROOT").unwrap_or_else(|_| resolve_emscripten_root());
+
+    config
+        .define(
+            "CMAKE_TOOLCHAIN_FILE",
+            format!("{vcpkg_root}/scripts/buildsystems/vcpkg.cmake"),
+        )
+        .define("VCPKG_TARGET_TRIPLET", &target_triplet)
+        .define("VCPKG_INSTALLED_DIR", &installed_dir)
+        .define("Threads_FOUND", "TRUE")
+        .define("CMAKE_THREAD_LIBS_INIT", "")
+        .define("CMAKE_USE_PTHREADS_INIT", "FALSE")
+        .define(
+            "VCPKG_CHAINLOAD_TOOLCHAIN_FILE",
+            format!("{emscripten_root}/cmake/Modules/Platform/Emscripten.cmake"),
+        );
+}
+
+fn repo_root_from_manifest_dir() -> PathBuf {
+    let mut path =
+        PathBuf::from(env::var("CARGO_MANIFEST_DIR").expect("CARGO_MANIFEST_DIR not set"));
+    for _ in 0..5 {
+        path.pop();
+    }
+    path
+}
+
+fn resolve_emscripten_root() -> String {
+    if let Ok(value) = env::var("EMSDK") {
+        let candidate = PathBuf::from(value).join("upstream").join("emscripten");
+        if candidate.join("cmake/Modules/Platform/Emscripten.cmake").exists() {
+            return candidate.display().to_string();
+        }
+    }
+
+    let output = Command::new("em-config")
+        .arg("EMSCRIPTEN_ROOT")
+        .output()
+        .expect("Failed to run `em-config EMSCRIPTEN_ROOT`");
+
+    if !output.status.success() {
+        panic!(
+            "`em-config EMSCRIPTEN_ROOT` failed with status {}",
+            output.status
+        );
+    }
+
+    String::from_utf8(output.stdout)
+        .expect("`em-config EMSCRIPTEN_ROOT` returned non-UTF8 output")
+        .trim()
+        .to_string()
+}
